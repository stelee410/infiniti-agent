{
  "name": "linkyun-infiniti-agent",
  "version": "0.5.0",
  "description": "LinkYun Infiniti Agent — long-running CLI agent (Node.js, React + Ink TUI)",
  "type": "module",
  "files": [
    "dist",
    "SOUL.md",
    "INFINITI.md",
    "docs"
  ],
  "bin": {
    "infiniti-agent": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "dev": "tsx src/cli.tsx",
    "dev:cli": "tsx src/cli.tsx --cli",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stelee410/infiniti-agent.git"
  },
  "bugs": {
    "url": "https://github.com/stelee410/infiniti-agent/issues"
  },
  "homepage": "https://github.com/stelee410/infiniti-agent#readme",
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "linkyun",
    "cli",
    "agent",
    "ink",
    "react"
  ],
  "license": "UNLICENSED",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@google/generative-ai": "^0.24.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chokidar": "^5.0.0",
    "commander": "^14.0.3",
    "diff": "^8.0.4",
    "fast-glob": "^3.3.3",
    "ink": "^5.2.0",
    "ink-select-input": "^6.2.0",
    "ink-text-input": "^6.0.0",
    "openai": "^6.33.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.4"
  }
}
